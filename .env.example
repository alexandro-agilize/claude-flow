# claude-flow — Variáveis de Ambiente
# Copie para .env e preencha os valores

# Servidor
PORT=3000

# Banco de dados (Módulo 3)
DATABASE_URL="file:./db/claude-flow.db"

# Claude AI (Módulo 2 — nó claude)
ANTHROPIC_API_KEY=

# Email / SMTP (Módulo 4 — nó email)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Slack (Módulo 4 — nó slack)
SLACK_BOT_TOKEN=

# PostgreSQL externo (Módulo 4 — nó postgres)
POSTGRES_URL=
